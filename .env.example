# ── Server Identity ──
SERVER_NAME=ZomboidServer
SERVER_PASSWORD=changeme
ADMIN_PASSWORD=adminchangeme

# ── Players ──
MAX_PLAYERS=8

# ── Steam Workshop Mods (comma-separated Workshop IDs) ──
# Example: MOD_IDS=2313387159,2392709985
MOD_IDS=
MOD_WORKSHOP_IDS=

# ── Server Performance ──
SERVER_MEMORY=4096m

# ── RCON (remote console) ──
RCON_PASSWORD=rconchangeme
RCON_PORT=27015

# ── Ports ──
GAME_PORT=16261
DIRECT_PORT=16262

# ── Backups ──
BACKUP_CRON=0 */6 * * *
BACKUP_RETENTION_DAYS=7

# ── Timezone ──
TZ=Europe/Berlin
